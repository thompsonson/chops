{
  "$schema": "https://raw.githubusercontent.com/nicedoc/html/master/tauri-conf-v2.json",
  "productName": "chops",
  "version": "0.1.0",
  "identifier": "dev.chops.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "chops",
        "width": 800,
        "height": 900,
        "minWidth": 400,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws: wss: http: https:; frame-src http: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "android": {
      "minSdkVersion": 26
    }
  }
}
